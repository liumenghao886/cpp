// 自定义比较函数（按长度升序，长度相同按字母升序）
bool cmpStrLen(const string& a, const string& b) {
    if (a.size() != b.size()) {
        // 长度短的排前面
        return a.size() < b.size();
    }
    // 长度相同，按字母升序（默认字符串比较规则）
    return a < b;
}

int main() {
    vector<string> strs;
    strs.push_back("apple");  // 长度5
    strs.push_back("pear");   // 长度4
    strs.push_back("banana"); // 长度6
    strs.push_back("cat");    // 长度3
    strs.push_back("ant");    // 长度3

    sort(strs.begin(), strs.end(), cmpStrLen);

    // 输出：ant cat pear apple banana
    cout << "\n按字符串长度排序：";
    for (int i=0; i<strs.size(); i++) {
        cout << strs[i] << " ";
    }
    return 0;
}
#include<bits/stdc++.h>
using namespace std;

// 自定义比较函数（按个位降序）
bool cmpLastDigit(const int& a, const int& b) {
    // 个位 = 数字 % 10；个位大的排前面 → a的个位 > b的个位时，a在前
    return (a % 10) > (b % 10);
}

int main() {
    vector<int> nums;
    nums.push_back(19);
    nums.push_back(28);
    nums.push_back(37);
    nums.push_back(46);
    nums.push_back(55);

    sort(nums.begin(), nums.end(), cmpLastDigit);

    // 输出：19 28 37 46 55（个位9→8→7→6→5）
    cout << "\n按个位降序：";
    for (int i=0; i<nums.size(); i++) {
        cout << nums[i] << " ";
    }
    return 0;
}
