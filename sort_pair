// C++98 兼容：自定义比较函数（按绝对值升序）
bool cmpAbs(const int& a, const int& b) {
    // 绝对值小的排前面 → a的绝对值 < b的绝对值时，a在前
    return abs(a) < abs(b);
}

int main() {
    // 初始化数组（C++98 方式）
    vector<int> nums;
    nums.push_back(-5);
    nums.push_back(2);
    nums.push_back(-9);
    nums.push_back(1);
    nums.push_back(5);

    // 用自定义规则排序
    sort(nums.begin(), nums.end(), cmpAbs);

    // 输出结果：1 2 -5 5 -9（绝对值从小到大）
    cout << "按绝对值升序：";
    for (int i=0; i<nums.size(); i++) {
        cout << nums[i] << " ";
    }
    return 0;
}
