void test05(stack<int> &s)
{
	s.push(10);
	s.push(20);
	s.push(30);
	s.push(40);
	//取栈，查看，不删除 
	cout<<s.top()<<endl;
	//出栈，删除栈顶
	s.pop();
	cout<<s.top()<<endl;
}
void test05(set<int> &st)
{
	st.insert(4);
	st.insert(2);
	st.insert(5);
	st.insert(1);
	st.insert(9);
	st.insert(8);
	st.insert(7);
	st.insert(3);

	//元素查找
	set<int>::iterator it=st.begin();
	for(;it!=st.end();it++)
	{
		cout<<*it<<" ";
	}
	cout<<endl;
	if(st.count(5)) 
	{
		cout<<"5存在"<<endl;
	}
	if(!st.count(6))
	{
		cout<<"6不存在"<<endl;
	}
	//迭代器查找
	set<int>::iterator it=st.find(6);
	if(it!=st.end()) 
	{
		cout<<"找到5了"<<endl;
	}
}
