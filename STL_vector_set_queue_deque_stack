void test01(vector<int> &v)
{
	
	//增 
	//尾增 
	v.push_back(10);
	v.push_back(20);
	v.push_back(30);
	v.push_back(40);
	//头增
	v.insert(v.begin(),9);
	v.insert(v.begin(),8); 
	//删
	//尾删
	v.pop_back();
	//头删
	v.erase(v.begin()); 
	//查
	cout<<v[0]<<endl;
	cout<<v.at(0)<<endl; 
	cout<<v.back()<<endl;
	cout<<v.front()<<endl;
	//大小，容量
	 cout<<"有多少元素："<<v.size()<<endl; 
	 cout<<"容量为："<<v.capacity()<<endl;
	 v.resize(1000);//改大小 
	 cout<<"有多少元素："<<v.size()<<endl;
}
void test02(list<int> &l)
{
	
	l.push_back(5);
	l.push_back(6);
	l.push_back(7);
	l.push_back(8);
	l.push_front(4);
	l.push_front(3);
	l.push_front(2);
	l.push_front(1);
	l.insert(l.begin(),0);
	list<int>::iterator it=l.begin();
	for(;it!=l.end();it++)
	{
		cout<<*it<<" ";
	}
	cout<<endl;
	l.pop_back();
	l.pop_front();
	it=l.begin();//删除首元素后重新获取初始迭代器 
	for(;it!=l.end();it++)
	{
		cout<<*it<<" ";
	}
	cout<<endl;
	//list不能随机访问，只能访问首尾
	cout<<"首："<<l.front()<<"尾："<<l.back()<<endl; 
	//l.clear();//删除所有元素 
	//it=l.begin();//删除首元素后重新获取初始迭代器 
	//for(;it!=l.end();it++)
	//{
	//	cout<<*it<<" ";
	//}
	l.remove(5);//删除所有值为x的元素 
		it=l.begin();//删除首元素后重新获取初始迭代器 
	for(;it!=l.end();it++)
	{
		cout<<*it<<" ";
	}
}
